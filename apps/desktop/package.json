{
  "name": "silverretort-desktop",
  "version": "0.1.0",
  "description": "SilverRetort Desktop Application",
  "main": "src/main.cjs",
  "scripts": {
    "dev": "electron .",
    "test": "node --test",
    "build:dir": "pnpm --filter silverretort-next run build && pnpm --filter silverretort-uvicorn run build && pnpm --filter silverretort-hermes run build && electron-builder --dir --publish never -c.directories.output=release-dir",
    "build": "pnpm --filter silverretort-next run build && pnpm --filter silverretort-uvicorn run build && pnpm --filter silverretort-hermes run build && electron-builder --publish never"
  },
  "build": {
    "appId": "com.silverretort.app",
    "productName": "SilverRetort",
    "asar": false,
    "directories": {
      "output": "release"
    },
    "files": [
      "package.json",
      "index.html",
      "src/**/*",
      "assets/**/*"
    ],
    "extraResources": [
      {
        "from": "../next/.next/desktop-static",
        "to": "frontend",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../uvicorn/dist",
        "to": "uvicorn",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../hermes/dist",
        "to": "hermes",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "icon": "assets/icon.ico",
      "signAndEditExecutable": false,
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "devDependencies": {
    "electron": "41.0.4",
    "electron-builder": "26.8.1"
  }
}
